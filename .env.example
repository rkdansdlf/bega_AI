## KBO AI Service Configuration

# Local dev: copy to `.env`
# Docker/prod-style runs: copy the repo root `.env.prod.example` to `.env.prod`

# LLM Provider (대화용)
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/free
OPENROUTER_FALLBACK_MODELS=openai/gpt-oss-120b
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_TITLE=KBO Chatbot
VISION_MODEL=google/gemma-4-31b-it:free
VISION_FALLBACK_MODELS=mistralai/mistral-small-3.2-24b-instruct
# Optional for normal serving. The routing gate requires exact coverage for every explicit provider/model label.
# Non-production illustrative catalog only; use operator-approved decimal-string rates outside this example.
CHAT_MODEL_PRICING_JSON={"example-provider":{"example/planner-model":{"input_usd_per_1m_tokens":"0.10","output_usd_per_1m_tokens":"0.20"},"example/answer-model":{"input_usd_per_1m_tokens":"1.00","output_usd_per_1m_tokens":"2.00"}}}

# Coach LLM Provider (코치 분석용)
COACH_LLM_PROVIDER=openrouter
COACH_OPENROUTER_MODEL=openrouter/free
COACH_OPENROUTER_FALLBACK_MODELS=openrouter/free
COACH_MAX_OUTPUT_TOKENS=2000
COACH_BRIEF_MAX_OUTPUT_TOKENS=8000
COACH_LLM_READ_TIMEOUT=10
# Coach legacy endpoint compatibility switch.
# Keep enabled during observation. Set to 0 only after 7 consecutive prod days with no legacy calls.
COACH_ANALYZE_LEGACY_ENABLED=1

# Embedding Provider (임베딩용 - OpenAI 직접 사용)
EMBED_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBED_MODEL=text-embedding-3-small

# Alternative: Gemini for both LLM and Embeddings
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-1.5-flash
# EMBED_PROVIDER=gemini
# GEMINI_EMBED_MODEL=text-embedding-004

# Database Configuration (PostgreSQL pgvector)
# AI 서비스 기본 DB (단일, Legacy FIREBASE/FIRESTORE는 미사용)
POSTGRES_DB_URL=postgresql://user:password@postgres-host:5432/database
# `auto` keeps local startup compatibility; use `managed` only after running
# scripts/migrate_ai_runtime_schema.sh with the migration role.
AI_DB_SCHEMA_MODE=auto
# Optional fallback for ops scripts that still read OCI_DB_URL
# OCI_DB_URL=postgresql://user:password@postgres-host:5432/database

# Other Settings
DEFAULT_SEARCH_LIMIT=6
MAX_OUTPUT_TOKENS=1024
RAG_CHUNK_TARGET_CHARS=650
RAG_CHUNK_MAX_CHARS=900
RAG_CHUNK_MIN_CHARS=180
RAG_CHUNK_OVERLAP_CHARS=80
RAG_QUALITY_MIN_CHARS=50
RAG_STORAGE_DEDUP_ENABLED=true
RAG_EMBEDDING_VERSION=2
RAG_CHUNKING_VERSION=1
RAG_RETRIEVAL_ACTIVE_FILTER_ENABLED=true
RAG_RETRIEVAL_EVENT_LOGGING_ENABLED=true
RAG_RERANK_ENABLED=false
RAG_RERANK_CANDIDATE_LIMIT=20
RAG_CONTEXT_LIMIT=10

# 벡터 인덱스 타입 (pgvector)
# "hnsw"     - HNSW 인덱스 사용 (scripts/create_vector_index.py 실행 후 설정)
# "ivfflat"  - 구형 IVFFlat 인덱스 사용 (레거시)
# "auto"     - 서비스 기동 시 pg_indexes에서 자동 감지 (기본값, 권장)
AI_VECTOR_INDEX=auto

# HNSW ef_search: 검색 시 후보 목록 크기 (정확도↑ = 값↑, 속도↑ = 값↓, 기본 100)
RETRIEVAL_HNSW_EF_SEARCH=100

# IVFFlat probes: 레거시 ivfflat 인덱스 전용 (기본 32, HNSW 전환 후 불필요)
RETRIEVAL_IVFFLAT_PROBES=32

# Chat cache admin API (기본 비활성)
# 운영에서 내부 관리 API를 사용할 때만 true로 설정하세요.
CHAT_CACHE_ADMIN_ENABLED=false
# CHAT_CACHE_ADMIN_TOKEN=replace-with-strong-random-token

# Chatbot model request queue (protects free/limited RPM models)
CHAT_QUEUE_ENABLED=true
CHAT_QUEUE_RPM_LIMIT=18
CHAT_QUEUE_WINDOW_SECONDS=60
CHAT_QUEUE_MAX_SIZE=60
CHAT_QUEUE_MAX_WAIT_SECONDS=180
CHAT_QUEUE_STATUS_INTERVAL_SECONDS=1

# Operator-provided P0 data fast-path (default off)
OPERATOR_DATA_FAST_PATH_ENABLED=false

# AI 내부 토큰
# Backend와 공통으로 사용하는 내부 인증 키입니다.
# 직접 AI 서비스 호출(직접 엔드포인트 테스트/운영 비인가 차단 포함)에서 필요합니다.
# BFF(/api/ai/*) 경유 시에는 Backend가 이 값을 주입합니다.
# 운영 기본 정책: 외부에서 /ai/* 직접 호출은 금지하고, 내부 경로에서만 허용합니다.
# Local dev fallback token. Override with a strong random token outside local-only environments.
AI_INTERNAL_TOKEN=local-dev-ai-internal-token

# CORS (credentials 사용 시 '*' 는 허용되지 않음)
# JSON 배열 형식과 CSV 형식을 모두 허용합니다.
# 예: ["http://localhost:5176", "http://127.0.0.1:5176"]
#CORS_ORIGINS=["http://localhost:5176", "http://127.0.0.1:5176", "http://localhost:5177", "http://127.0.0.1:5177"]
